{
	"allowedScopes": [
		"environment"
	],
	"constraints": [
		{
			"customValidatorId": "validate-complex-props",
			"skipAsyncValidation": false,
			"type": "CUSTOM_VALIDATOR_REF"
		}
	],
	"description": "Create new guardians and add objectives. [See documentation](https://dt-url.net/site-reliability-guardian)",
	"displayName": "Site Reliability Guardian",
	"documentation": "",
	"dynatrace": "1",
	"enums": {
		"ComparisonOperator": {
			"description": "Pass/fail direction: use ≥ when higher values are better, ≤ when lower values are better.",
			"displayName": "Comparison operator",
			"documentation": "",
			"items": [
				{
					"description": "Use when a higher measured value indicates better performance, e.g. availability or throughput.",
					"displayName": "Greater than or equal",
					"value": "GREATER_THAN_OR_EQUAL"
				},
				{
					"description": "Use when a lower measured value indicates better performance, e.g. response time or error rate.",
					"displayName": "Less than or equal",
					"value": "LESS_THAN_OR_EQUAL"
				}
			],
			"type": "enum"
		},
		"EventKind": {
			"description": "Controls where validation events are stored: BIZ_EVENT for Grail bizevents, SDLC_EVENT for the SDLC pipeline.",
			"displayName": "Event kind",
			"documentation": "",
			"items": [
				{
					"description": "Store validation results as business events in Grail. Default for business guardians.",
					"displayName": "Biz events",
					"value": "BIZ_EVENT"
				},
				{
					"description": "Store validation results as SDLC events. Intended for software delivery lifecycle pipelines.",
					"displayName": "SDLC events",
					"value": "SDLC_EVENT"
				}
			],
			"type": "enum"
		},
		"ObjectiveType": {
			"description": "How the objective value is computed: via a DQL query or an existing SLO metric.",
			"displayName": "Objective type",
			"documentation": "",
			"items": [
				{
					"description": "Run a DQL query; the first numeric result becomes the indicator value.",
					"displayName": "DQL",
					"value": "DQL"
				},
				{
					"description": "Use an existing SLO metric as the indicator. The metric key must start with 'func:slo.'.",
					"displayName": "Reference SLO",
					"value": "REFERENCE_SLO"
				}
			],
			"type": "enum"
		}
	},
	"maturity": "GENERAL_AVAILABILITY",
	"maxObjects": 1000,
	"metadata": {
		"addItemButton": "Add Site Reliability Guardian",
		"appName": "Site Reliability Guardian"
	},
	"multiObject": true,
	"ordered": false,
	"properties": {
		"description": {
			"constraints": [
				{
					"maxLength": 250,
					"minLength": 1,
					"type": "LENGTH"
				}
			],
			"description": "Optional explanation of this guardian's purpose and scope.",
			"displayName": "Description",
			"documentation": "",
			"maxObjects": 1,
			"modificationPolicy": "DEFAULT",
			"nullable": true,
			"type": "text"
		},
		"eventKind": {
			"description": "If set to null/'BIZ_EVENT' validation events stored as bizevents in Grail. If set to 'SDLC_EVENT' validation events stored as SDLC events ",
			"displayName": "Event kind",
			"documentation": "",
			"maxObjects": 1,
			"modificationPolicy": "DEFAULT",
			"nullable": true,
			"type": {
				"$ref": "#/enums/EventKind"
			}
		},
		"name": {
			"constraints": [
				{
					"maxLength": 200,
					"minLength": 1,
					"type": "LENGTH"
				}
			],
			"default": "New reliability guardian",
			"description": "Unique display name for this guardian.",
			"displayName": "Name",
			"documentation": "",
			"maxObjects": 1,
			"modificationPolicy": "DEFAULT",
			"nullable": false,
			"type": "text"
		},
		"objectives": {
			"constraints": [
				{
					"customMessage": "There is another objective in this guardian with an identical name defined. Please make your objective name unique to save your changes.",
					"type": "UNIQUE",
					"uniqueProperties": [
						"name"
					]
				}
			],
			"description": "The validation criteria evaluated each time this guardian is executed.",
			"displayName": "Objectives",
			"documentation": "",
			"items": {
				"description": "",
				"displayName": "",
				"documentation": "",
				"type": {
					"$ref": "#/types/Objective"
				}
			},
			"maxObjects": 50,
			"metadata": {
				"addItemButton": "Add objective"
			},
			"minObjects": 1,
			"modificationPolicy": "DEFAULT",
			"nullable": false,
			"type": "list"
		},
		"tags": {
			"description": "Define key/value pairs that further describe this guardian.",
			"displayName": "Tags",
			"documentation": "",
			"items": {
				"constraints": [
					{
						"customValidatorId": "builtin:universal-tag-validator",
						"skipAsyncValidation": false,
						"type": "CUSTOM_VALIDATOR_REF",
						"validatorUrl": "builtin:universal-tag-validator"
					},
					{
						"maxLength": 500,
						"minLength": 1,
						"type": "LENGTH"
					},
					{
						"customValidatorId": "universal-tag-validator",
						"skipAsyncValidation": false,
						"type": "CUSTOM_VALIDATOR_REF"
					}
				],
				"description": "",
				"displayName": "",
				"documentation": "",
				"subType": "tag",
				"type": "text"
			},
			"maxObjects": 100,
			"metadata": {
				"addItemButton": "Add tag"
			},
			"minObjects": 0,
			"modificationPolicy": "DEFAULT",
			"nullable": false,
			"type": "set"
		},
		"variables": {
			"constraints": [
				{
					"customMessage": "There is another variable in this guardian with an identical name defined. Please make your variable name unique to save your changes.",
					"type": "UNIQUE",
					"uniqueProperties": [
						"name"
					]
				}
			],
			"description": "Define variables for dynamically defining DQL queries",
			"displayName": "DQL variables",
			"documentation": "",
			"items": {
				"description": "",
				"displayName": "",
				"documentation": "",
				"type": {
					"$ref": "#/types/Variable"
				}
			},
			"maxObjects": 100,
			"metadata": {
				"addItemButton": "Add variable"
			},
			"minObjects": 0,
			"modificationPolicy": "DEFAULT",
			"nullable": false,
			"type": "list"
		}
	},
	"schemaConstraints": [
		{
			"customMessage": "There is another guardian with an identical name defined. Please make your guardian name unique to save your changes.",
			"flattenCollections": false,
			"type": "UNIQUE",
			"uniqueProperties": [
				"name"
			]
		}
	],
	"schemaId": "app:dynatrace.site.reliability.guardian:guardians",
	"types": {
		"DisplayUnit": {
			"description": "Defines unit conversion and decimal formatting applied when showing a DQL result in the UI.",
			"displayName": "Display Unit",
			"documentation": "",
			"properties": {
				"base": {
					"constraints": [
						{
							"maxLength": 20,
							"minLength": 1,
							"type": "LENGTH"
						}
					],
					"default": "None",
					"description": "Unit the DQL query returns its result in. Source unit for conversion.",
					"displayName": "Base Unit",
					"documentation": "",
					"maxObjects": 1,
					"modificationPolicy": "DEFAULT",
					"nullable": false,
					"type": "text"
				},
				"decimals": {
					"constraints": [
						{
							"maximum": 4,
							"minimum": 0,
							"type": "RANGE"
						}
					],
					"default": 2,
					"description": "Number of decimal places (0-4) used when formatting the displayed value.",
					"displayName": "Decimals",
					"documentation": "",
					"maxObjects": 1,
					"modificationPolicy": "DEFAULT",
					"nullable": false,
					"type": "integer"
				},
				"display": {
					"constraints": [
						{
							"maxLength": 20,
							"minLength": 1,
							"type": "LENGTH"
						}
					],
					"default": "Default",
					"description": "Unit to display the value in after conversion. Use Default to show the base unit as-is.",
					"displayName": "display as unit",
					"documentation": "",
					"maxObjects": 1,
					"modificationPolicy": "DEFAULT",
					"nullable": false,
					"type": "text"
				}
			},
			"summaryPattern": "{base} -\u003e {display}",
			"type": "object",
			"version": "0",
			"versionInfo": ""
		},
		"Objective": {
			"description": "A single validation criterion evaluated each guardian run. Result is pass, warning, fail, or info depending on thresholds and the comparison operator.",
			"displayName": "Objective",
			"documentation": "",
			"properties": {
				"autoAdaptiveThresholdEnabled": {
					"description": "Dynamically computes thresholds from 30 days of history.",
					"displayName": "Enable auto adaptive threshold",
					"documentation": "",
					"maxObjects": 1,
					"modificationPolicy": "DEFAULT",
					"nullable": true,
					"precondition": {
						"expectedValue": "DQL",
						"property": "objectiveType",
						"type": "EQUALS"
					},
					"type": "boolean"
				},
				"comparisonOperator": {
					"default": "GREATER_THAN_OR_EQUAL",
					"description": "Pass/fail direction: use ≥ when higher values are better, ≤ when lower values are better.",
					"displayName": "Comparison operator",
					"documentation": "",
					"maxObjects": 1,
					"modificationPolicy": "DEFAULT",
					"nullable": false,
					"type": {
						"$ref": "#/enums/ComparisonOperator"
					}
				},
				"description": {
					"constraints": [
						{
							"maxLength": 250,
							"minLength": 1,
							"type": "LENGTH"
						}
					],
					"description": "Optional short explanation of what this objective measures.",
					"displayName": "Description",
					"documentation": "",
					"maxObjects": 1,
					"modificationPolicy": "DEFAULT",
					"nullable": true,
					"type": "text"
				},
				"displayUnit": {
					"description": "Optional unit conversion and decimal formatting applied when displaying the DQL result in the UI.",
					"displayName": "Display Unit",
					"documentation": "",
					"maxObjects": 1,
					"modificationPolicy": "DEFAULT",
					"nullable": true,
					"precondition": {
						"expectedValue": "DQL",
						"property": "objectiveType",
						"type": "EQUALS"
					},
					"type": {
						"$ref": "#/types/DisplayUnit"
					}
				},
				"dqlQuery": {
					"constraints": [
						{
							"maxLength": 4000,
							"minLength": 1,
							"type": "LENGTH"
						}
					],
					"default": "",
					"description": "DQL query to execute. The first numeric result becomes the objective value. Supports $variable interpolation.",
					"displayName": "DQL query",
					"documentation": "",
					"maxObjects": 1,
					"modificationPolicy": "DEFAULT",
					"nullable": false,
					"precondition": {
						"expectedValue": "DQL",
						"property": "objectiveType",
						"type": "EQUALS"
					},
					"subType": "code",
					"type": "text"
				},
				"links": {
					"description": "Fields for adding relevant links to this objective.",
					"displayName": "Links",
					"documentation": "",
					"items": {
						"description": "",
						"displayName": "",
						"documentation": "",
						"type": {
							"$ref": "#/types/ObjectiveLink"
						}
					},
					"maxObjects": 5,
					"metadata": {
						"addItemButton": "Add link"
					},
					"minObjects": 0,
					"modificationPolicy": "DEFAULT",
					"nullable": false,
					"type": "list"
				},
				"name": {
					"constraints": [
						{
							"maxLength": 200,
							"minLength": 1,
							"type": "LENGTH"
						}
					],
					"default": "New objective name",
					"description": "Unique name within this guardian. Included in every emitted validation event as the objective identifier.",
					"displayName": "Objective name",
					"documentation": "",
					"maxObjects": 1,
					"modificationPolicy": "DEFAULT",
					"nullable": false,
					"type": "text"
				},
				"objectiveType": {
					"default": "DQL",
					"description": "How the objective value is computed: via a DQL query or an existing SLO metric.",
					"displayName": "Objective type",
					"documentation": "",
					"maxObjects": 1,
					"modificationPolicy": "DEFAULT",
					"nullable": false,
					"type": {
						"$ref": "#/enums/ObjectiveType"
					}
				},
				"referenceSlo": {
					"constraints": [
						{
							"maxLength": 800,
							"minLength": 1,
							"type": "LENGTH"
						}
					],
					"default": "",
					"description": "Please enter the metric key of your desired SLO. SLO metric keys have to start with 'func:slo.'",
					"displayName": "Reference SLO",
					"documentation": "",
					"maxObjects": 1,
					"modificationPolicy": "DEFAULT",
					"nullable": false,
					"precondition": {
						"expectedValue": "REFERENCE_SLO",
						"property": "objectiveType",
						"type": "EQUALS"
					},
					"type": "text"
				},
				"segments": {
					"description": "Optional Grail segments to scope the DQL query to specific data.",
					"displayName": "Segments",
					"documentation": "",
					"items": {
						"description": "",
						"displayName": "",
						"documentation": "",
						"type": {
							"$ref": "#/types/Segment"
						}
					},
					"maxObjects": 100,
					"minObjects": 0,
					"modificationPolicy": "DEFAULT",
					"nullable": false,
					"type": "list"
				},
				"target": {
					"description": "Hard pass/fail threshold. Missing this value yields FAIL. If unset with no warning, status is always INFO.",
					"displayName": "Target",
					"documentation": "",
					"maxObjects": 1,
					"modificationPolicy": "DEFAULT",
					"nullable": true,
					"type": "float"
				},
				"warning": {
					"description": "Soft threshold. Results between warning and target yield WARNING. When set alone, yields PASS or WARNING.",
					"displayName": "Warning",
					"documentation": "",
					"maxObjects": 1,
					"modificationPolicy": "DEFAULT",
					"nullable": true,
					"type": "float"
				}
			},
			"summaryPattern": "{name}",
			"type": "object",
			"version": "0",
			"versionInfo": ""
		},
		"ObjectiveLink": {
			"description": "An external HTTPS URL with optional display text attached to an objective for contextual reference.",
			"displayName": "Objective Link",
			"documentation": "",
			"properties": {
				"label": {
					"constraints": [
						{
							"maxLength": 200,
							"minLength": 1,
							"type": "LENGTH"
						}
					],
					"description": "Short description for the link.",
					"displayName": "Display text",
					"documentation": "",
					"maxObjects": 1,
					"modificationPolicy": "DEFAULT",
					"nullable": true,
					"type": "text"
				},
				"url": {
					"constraints": [
						{
							"maxLength": 4096,
							"type": "LENGTH"
						},
						{
							"pattern": "^https://.*$",
							"type": "PATTERN"
						},
						{
							"customMessage": "Not a valid URI",
							"pattern": "^(([^\\s:/?#]+?):){1}((//)?([^\\s/?#]+?)){1}([^\\s?#]*?)(\\?([^\\s#]*?))?(#([^\\s]*?))?$",
							"type": "PATTERN"
						},
						{
							"customMessage": "Not a valid http(s) URL",
							"pattern": "^https?://.*$",
							"type": "PATTERN"
						}
					],
					"default": "",
					"description": "HTTPS link associated with this objective.",
					"displayName": "URL",
					"documentation": "",
					"maxObjects": 1,
					"modificationPolicy": "DEFAULT",
					"nullable": false,
					"subType": "url",
					"type": "text"
				}
			},
			"summaryPattern": "{label}",
			"type": "object",
			"version": "0",
			"versionInfo": ""
		},
		"Segment": {
			"description": "A Grail segment reference that scopes a DQL objective query to a subset of observability data.",
			"displayName": "Segment",
			"documentation": "",
			"properties": {
				"id": {
					"constraints": [
						{
							"maxLength": 200,
							"minLength": 10,
							"type": "LENGTH"
						}
					],
					"default": "",
					"description": "Dynatrace Grail segment ID that scopes the DQL query to data within the segment.",
					"displayName": "Segment ID",
					"documentation": "",
					"maxObjects": 1,
					"modificationPolicy": "DEFAULT",
					"nullable": false,
					"type": "text"
				},
				"variables": {
					"description": "Variables to parameterize the segment filter.",
					"displayName": "Segment Variables",
					"documentation": "",
					"items": {
						"description": "",
						"displayName": "",
						"documentation": "",
						"type": {
							"$ref": "#/types/SegmentVariable"
						}
					},
					"maxObjects": 100,
					"minObjects": 0,
					"modificationPolicy": "DEFAULT",
					"nullable": false,
					"type": "list"
				}
			},
			"summaryPattern": "{id}",
			"type": "object",
			"version": "0",
			"versionInfo": ""
		},
		"SegmentVariable": {
			"description": "A named variable within a segment used to parameterize the segment filter.",
			"displayName": "Segment Variable",
			"documentation": "",
			"properties": {
				"name": {
					"constraints": [
						{
							"maxLength": 500,
							"minLength": 1,
							"type": "LENGTH"
						}
					],
					"default": "",
					"description": "Name of the variable within the segment definition.",
					"displayName": "Variable Name",
					"documentation": "",
					"maxObjects": 1,
					"modificationPolicy": "DEFAULT",
					"nullable": false,
					"type": "text"
				},
				"values": {
					"description": "One or more values for the variable, enabling multi-value filter expansion.",
					"displayName": "Variable Values",
					"documentation": "",
					"items": {
						"constraints": [
							{
								"maxLength": 500,
								"minLength": 1,
								"type": "LENGTH"
							}
						],
						"description": "",
						"displayName": "",
						"documentation": "",
						"type": "text"
					},
					"maxObjects": 100,
					"minObjects": 0,
					"modificationPolicy": "DEFAULT",
					"nullable": false,
					"type": "list"
				}
			},
			"summaryPattern": "{name}",
			"type": "object",
			"version": "0",
			"versionInfo": ""
		},
		"Variable": {
			"description": "Named placeholder referenced as $name in DQL queries. Default value is used unless overridden via execution context.",
			"displayName": "Variable",
			"documentation": "",
			"properties": {
				"definition": {
					"constraints": [
						{
							"maxLength": 1000,
							"minLength": 1,
							"type": "LENGTH"
						}
					],
					"default": "",
					"description": "Default value substituted for $name in DQL queries. Can be overridden at runtime via execution context.",
					"displayName": "Value",
					"documentation": "",
					"maxObjects": 1,
					"modificationPolicy": "DEFAULT",
					"nullable": false,
					"type": "text"
				},
				"name": {
					"constraints": [
						{
							"maxLength": 200,
							"minLength": 1,
							"type": "LENGTH"
						},
						{
							"pattern": "^[A-Za-z0-9_]+$",
							"type": "PATTERN"
						}
					],
					"default": "",
					"description": "Alphanumeric/underscore identifier referenced in DQL queries as $name. Must be unique within the guardian.",
					"displayName": "Name",
					"documentation": "",
					"maxObjects": 1,
					"modificationPolicy": "DEFAULT",
					"nullable": false,
					"type": "text"
				}
			},
			"summaryPattern": "{name}",
			"type": "object",
			"version": "0",
			"versionInfo": ""
		}
	},
	"version": "1.9.1"
}