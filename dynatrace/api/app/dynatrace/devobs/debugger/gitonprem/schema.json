{
	"allowedScopes": [
		"environment"
	],
	"description": "Specify your On-Premise Git servers to be able to fetch source code from them",
	"displayName": "Git On-Premise Servers",
	"documentation": "",
	"dynatrace": "1",
	"enums": {
		"providers": {
			"description": "",
			"displayName": "Git Providers",
			"documentation": "",
			"items": [
				{
					"displayName": "Github",
					"value": "GithubOnPrem"
				},
				{
					"displayName": "Gitlab",
					"value": "GitlabOnPrem"
				},
				{
					"displayName": "Bitbucket",
					"value": "BitbucketOnPrem"
				},
				{
					"displayName": "Azure Devops",
					"value": "AzureOnPrem"
				}
			],
			"type": "enum"
		}
	},
	"maturity": "GENERAL_AVAILABILITY",
	"maxObjects": 10,
	"metadata": {
		"appName": "Live Debugger"
	},
	"multiObject": true,
	"ordered": false,
	"properties": {
		"IncludeCredentials": {
			"default": false,
			"description": "If turned on, requests to your Gitlab server will have the `credentials` option set to `include`. Otherwise, it will be set to `omit`.",
			"displayName": "Include Credentials",
			"documentation": "",
			"maxObjects": 1,
			"modificationPolicy": "DEFAULT",
			"nullable": false,
			"precondition": {
				"expectedValue": "GitlabOnPrem",
				"property": "Provider",
				"type": "EQUALS"
			},
			"type": "boolean"
		},
		"Provider": {
			"default": "GithubOnPrem",
			"description": "The git service provider for this server",
			"displayName": "Git Provider",
			"documentation": "",
			"maxObjects": 1,
			"modificationPolicy": "DEFAULT",
			"nullable": false,
			"type": {
				"$ref": "#/enums/providers"
			}
		},
		"Url": {
			"constraints": [
				{
					"customMessage": "Not a valid HTTP or HTTPS URL.",
					"pattern": "^https?://\\S+(/\\S)*$",
					"type": "PATTERN"
				},
				{
					"customMessage": "The server URL must be an HTTPS base URL without a path (for example https://git.example.com).",
					"customValidatorId": "validate-git-on-prem-url",
					"skipAsyncValidation": false,
					"type": "CUSTOM_VALIDATOR_REF"
				},
				{
					"maxLength": 500,
					"minLength": 1,
					"type": "LENGTH"
				}
			],
			"default": "",
			"description": "An HTTPS URL of your server (HTTP not supported)\nProvide only the base URL of the server, not a path to a specific project or repository (For instance, https://git.example.com)",
			"displayName": "Server URL",
			"documentation": "",
			"maxObjects": 1,
			"modificationPolicy": "DEFAULT",
			"nullable": false,
			"type": "text"
		}
	},
	"schemaId": "app:dynatrace.devobs.debugger:git.on.prem",
	"types": {},
	"version": "0.5"
}