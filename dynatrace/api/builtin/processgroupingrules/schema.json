		"ProcessGroupExtraction": {
			"description": "",
			"displayName": "ProcessGroupExtraction",
			"documentation": "",
			"properties": {
				"detection": {
					"description": "### 2. Define detection rules\n Define process detection rules to select processes on which this rule will apply to. **At least one rule must be defined.**",
					"displayName": "",
					"documentation": "",
					"items": {
						"description": "",
						"displayName": "",
						"documentation": "",
						"type": {
							"$ref": "#/types/DetectionCondition"
						}
					},
					"maxObjects": 100,
					"metadata": {
						"addItemButton": "Add detection rule",
						"itemDisplayName": "New detection rule"
					},
					"minObjects": 1,
					"modificationPolicy": "DEFAULT",
					"nullable": false,
					"type": "list",
					"uiCustomization": {
						"table": {
							"columns": [
								{
