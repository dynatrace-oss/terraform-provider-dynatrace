		"AdvancedSettings": {
			"description": "",
			"displayName": "Advanced Settings",
			"documentation": "",
			"properties": {
				"from": {
					"constraints": [
						{
							"maxLength": 500,
							"minLength": 1,
							"type": "LENGTH"
						},
						{
							"customMessage": "Separators (comma, colon, semicolon) aren't allowed.",
							"pattern": "^[^,:;]*$",
							"type": "PATTERN"
						}
					],
					"description": "",
					"displayName": "Delimit from (optional)",
					"documentation": "",
					"maxObjects": 1,
					"metadata": {
						"placeholder": "eg. --env="
					},
					"modificationPolicy": "DEFAULT",
					"nullable": true,
					"type": "text"
				},
				"ignoreNumbers": {
					"default": false,
					"description": "(e.g. versions, hex, dates, and build numbers)",
					"displayName": "Ignore numbers",
					"documentation": "",
					"maxObjects": 1,
					"modificationPolicy": "DEFAULT",
					"nullable": false,
					"type": "boolean"
				},
				"to": {
					"constraints": [
						{
							"maxLength": 500,
							"minLength": 1,
							"type": "LENGTH"
						},
						{
							"customMessage": "Separators (comma, colon, semicolon) aren't allowed.",
							"pattern": "^[^,:;]*$",
							"type": "PATTERN"
						}
					],
					"description": "",
					"displayName": "Delimit to (optional)",
					"documentation": "",
					"maxObjects": 1,
					"metadata": {
						"placeholder": "eg. --id"
					},
					"modificationPolicy": "DEFAULT",
					"nullable": true,
					"type": "text"
				}
			},
			"summaryPattern": "{from|valueSet, select, true {from: **{from}** } other {}} {to|valueSet, select, true {to: **{to}** } other {}}",
			"type": "object",
			"version": "0",
			"versionInfo": ""
		},
		"DetectionCondition": {
			"description": "",
			"displayName": "DetectionCondition",
			"documentation": "",
			"properties": {
				"caseSensitive": {
					"default": false,
					"description": "",
					"displayName": "Case sensitive",
					"documentation": "When enabled, matching conditions are case sensitive. When disabled, matching conditions are case insensitive",
					"maxObjects": 1,
					"modificationPolicy": "DEFAULT",
					"nullable": false,
					"type": "boolean"
				},
				"condition": {
					"constraints": [
						{
							"customMessage": "Should have one of the following formats: $prefix(parameter), $eq(parameter), $suffix(parameter), $contains(parameter)",
							"pattern": "^\\$(eq|prefix|suffix|contains)\\(((?:[^()$,~]|~[()])+?)\\)$",
							"type": "PATTERN"
						},
						{
							"maxLength": 1000,
							"minLength": 1,
							"type": "LENGTH"
						}
					],
					"default": "",
					"description": "- $contains(svc) – Matches if svc appears anywhere in the process property value.\n- $eq(svc.exe) – Matches if svc.exe matches the process property value exactly.\n- $prefix(svc) – Matches if app matches the prefix of the process property value.\n- $suffix(svc.py) – Matches if svc.py matches the suffix of the process property value.\n\nFor example, $suffix(svc.py) would detect processes named loyaltysvc.py and paymentssvc.py.\n\nFor more details, see [documentation](https://dt-url.net/j142w57).",
					"displayName": "2.2. Condition",
					"documentation": "",
					"maxObjects": 1,
					"metadata": {
						"placeholder": "Property condition to be detected"
					},
					"modificationPolicy": "DEFAULT",
					"nullable": false,
					"precondition": {
						"precondition": {
							"expectedValues": [
								"ENVIRONMENT_VARIABLE",
								"JAVA_SYS_PROP"
							],
							"property": "property",
							"type": "IN"
						},
						"type": "NOT"
					},
					"type": "text"
				},
				"name": {
					"constraints": [
						{
							"maxLength": 100,
							"minLength": 1,
							"type": "LENGTH"
						}
					],
					"default": "",
					"description": "If Dynatrace detects this property at startup of a process, it will be matched to this grouping rule.",
					"displayName": "2.2. Variable name",
					"documentation": "",
					"maxObjects": 1,
					"modificationPolicy": "DEFAULT",
					"nullable": false,
					"precondition": {
						"expectedValues": [
							"ENVIRONMENT_VARIABLE",
							"JAVA_SYS_PROP"
						],
						"property": "property",
						"type": "IN"
					},
					"type": "text"
				},
				"property": {
					"constraints": [
						{
							"maxLength": 500,
							"minLength": 1,
							"type": "LENGTH"
						}
					],
					"datasource": {
						"filterProperties": [],
						"fullContext": false,
						"identifier": "detectionPropertiesSource",
						"resetValue": "NEVER",
						"useApiSearch": false,
						"validate": true
					},
					"default": "",
					"description": "",
					"displayName": "2.1. Property",
					"documentation": "",
					"maxObjects": 1,
					"modificationPolicy": "DEFAULT",
					"nullable": false,
					"subType": "datasource",
					"type": "text"
				}
			},
			"summaryPattern": "**{property}** {name} {condition}",
			"type": "object",
			"version": "0",
			"versionInfo": ""
		},
		"GroupIdSource": {
			"description": "",
			"displayName": "",
			"documentation": "",
			"properties": {
				"advancedSettings": {
					"description": "Set advanced options to customize delimiters and control how property values are processed.",
					"displayName": "3.1.3. Advanced settings (optional)",
					"documentation": "Consider an environment with processes such as:\n * `python myScript.py --env=prod12 --id=12`\n * `python myScript.py --env=dev2 --id=2`\n * etc.\n\n To group production *(prod)* and development *(dev)* processes together you could use Command line property with:\n * **Delimiter** from `--env=` to `--id` to extract `prod12 ` and `dev2 `\n * Enable **Ignore numbers** to transform `prod12` to `prod*` and `dev2` to `dev*`.",
					"maxObjects": 1,
					"modificationPolicy": "DEFAULT",
					"nullable": true,
					"precondition": {
						"expectedValue": "EXISTING",
						"property": "type",
						"type": "EQUALS"
					},
					"type": {
						"$ref": "#/types/AdvancedSettings"
					}
				},
				"id": {
					"constraints": [
						{
							"maxLength": 100,
							"minLength": 1,
							"type": "LENGTH"
						}
					],
					"default": "",
					"description": "This identifier is used by Dynatrace to recognize this process group.",
					"displayName": "3.1.2. Process group identifier",
					"documentation": "",
					"maxObjects": 1,
					"metadata": {
						"placeholder": "Enter a string (no empty spaces)"
					},
					"modificationPolicy": "DEFAULT",
					"nullable": false,
					"precondition": {
						"expectedValue": "CUSTOM",
						"property": "type",
						"type": "EQUALS"
					},
					"type": "text"
				},
				"name": {
					"constraints": [
						{
							"maxLength": 500,
							"minLength": 1,
							"type": "LENGTH"
						}
					],
					"default": "",
					"description": "If Dynatrace detects this property at startup of a process, it will use its value to identify process groups.",
					"displayName": "Variable name",
					"documentation": "",
					"maxObjects": 1,
					"modificationPolicy": "DEFAULT",
					"nullable": false,
					"precondition": {
						"expectedValues": [
							"ENVIRONMENT_VARIABLE",
							"JAVA_SYS_PROP"
						],
						"property": "property",
						"type": "IN"
					},
					"type": "text"
				},
				"property": {
					"constraints": [
						{
							"maxLength": 500,
							"minLength": 1,
							"type": "LENGTH"
						}
					],
					"datasource": {
						"filterProperties": [],
						"fullContext": false,
						"identifier": "groupIdSource",
						"resetValue": "NEVER",
						"useApiSearch": false,
						"validate": true
					},
					"default": "EXE_NAME",
					"description": "",
					"displayName": "3.1.2. Property",
					"documentation": "",
					"maxObjects": 1,
					"modificationPolicy": "DEFAULT",
					"nullable": false,
					"precondition": {
						"expectedValue": "EXISTING",
						"property": "type",
						"type": "EQUALS"
					},
					"subType": "datasource",
					"type": "text"
				},
				"standaloneRule": {
					"default": true,
					"description": "Valid only for **deep monitored** processes.",
					"displayName": "Standalone rule",
					"documentation": "If this option is selected, the default Dynatrace behavior is disabled for the detected processes. Only this rule is used to separate the process group.\n\nIf this option is not selected, this rule contributes to the default Dynatrace process group detection. \n\n[See our help page for examples.](https://dt-url.net/1722wrz)",
					"maxObjects": 1,
					"modificationPolicy": "DEFAULT",
					"nullable": false,
					"type": "boolean"
				},
				"type": {
					"default": "CUSTOM",
					"description": "Pick which property should be used to identify your process group. You can pick a custom variable or pick an existing process property.",
					"displayName": "3.1.1. Id type",
					"documentation": "",
					"maxObjects": 1,
					"modificationPolicy": "DEFAULT",
					"nullable": false,
					"subType": "radio",
					"type": {
						"$ref": "#/enums/IdType"
					}
				}
			},
			"summaryPattern": "{id|valueSet, select, true {custom identifier **{id}**} other {}}{property|valueSet, select, true {**{property}**} other {}}{name|valueSet, select, true { {name}} other {}}{advancedSettings|valueSet, select, true { {advancedSettings}} other {}}",
			"type": "object",
			"version": "0",
			"versionInfo": ""
		},
